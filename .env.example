# Copia este archivo como .env.local y rellena con tus valores reales.
# El .env.local NO se sube a Git (contiene tus claves).

# URL del proyecto Supabase
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co

# Clave pública (publishable) de Supabase. Es segura para el frontal.
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxx

# Clave de SERVICIO (service_role) de Supabase. SECRETA, solo servidor.
# Omite RLS: se usa para crear/actualizar pedidos desde el servidor. NUNCA
# la pongas en una variable NEXT_PUBLIC_ ni la expongas al navegador.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxx

# Tenant (cliente) cuyo catálogo carga este kiosko
NEXT_PUBLIC_TENANT_SLUG=prosegur

# Identidad del kiosko físico (UUID de public.locations / panel → Kioskos).
# Alternativa sin rebuild: abrir el tótem con ?kiosk=<uuid> una vez; queda
# guardado en localStorage del dispositivo. El panel muestra la URL lista.
# NEXT_PUBLIC_KIOSK_LOCATION_ID=00000000-0000-0000-0000-000000000000

# ── Stripe (MODO TEST — nunca claves live aquí) ──
# Clave secreta de servidor. Recomendado usar una clave RESTRINGIDA de test
# (rk_test_...) en vez de la secreta completa (sk_test_...).
STRIPE_SECRET_KEY=rk_test_xxxxxxxxxxxxxxxx
# Clave pública (publishable) de test, usada por el navegador para el checkout.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxx
# Secreto de firma del webhook. En local lo da `stripe listen`; en producción,
# el endpoint configurado en el Dashboard de Stripe.
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxx

# ── Connect / Administración (Fase 3a) ──
# URL pública de la app. Se usa para construir return_url/refresh_url del
# onboarding de Stripe Connect. En local: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
# El onboarding de Connect se gestiona desde el panel autenticado
# (/panel/settings → Integraciones), protegido por sesión real y la capacidad
# settings.manage. Ya no existe el puente temporal /admin por token.

# ── Node.js / HTTP ──
# Aumenta el límite de cabeceras HTTP para CDNs que envían muchos headers
# (ej. Akamai). Necesario para el scraper de importación de catálogos.
NODE_OPTIONS=--max-http-header-size=81920

# ── Entrega del comprobante (Fase 3a.2) ──
# Claves de PLATAFORMA de los proveedores de mensajería. Las identidades de
# remitente (email from, números) van por tenant en tenants.entrega_config.
# Email vía Resend. Crea una en https://resend.com (modo test gratis).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
# SMS y WhatsApp vía Twilio (cuenta + sandbox). Solo servidor.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxx

# ── Autocompletado de destinos (Bolt) ──
# Google Places API (New): Autocomplete + Place Details. Nivel top para POIs
# (aeropuerto T4, hoteles…). En Google Cloud: habilita "Places API (New)" y
# restringe la key al servidor. Sin esta key se usa Nominatim (OSM) gratis.
GOOGLE_MAPS_API_KEY=

# ── Actualización batch del catálogo (cron nocturno) ──
# Secreto que protege /api/cron/actualizar-catalogo. El job de pg_cron envía
# este valor como "Authorization: Bearer <CRON_SECRET>". Debe COINCIDIR con el
# secreto guardado en Supabase Vault ('cron_secret'). Genera uno largo y único.
CRON_SECRET=pon-un-secreto-largo-y-aleatorio
# URL pública de la app usada por el cron (Vault 'app_url' debe apuntar aquí).
# En producción: https://tu-dominio. En local se dispara con el botón del panel.
APP_URL=https://tu-dominio.com
