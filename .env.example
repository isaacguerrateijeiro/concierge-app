# Copia este archivo como .env.local y rellena con tus valores reales.
# El .env.local NO se sube a Git (contiene tus claves).

# URL del proyecto Supabase
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co

# Clave pública (publishable) de Supabase. Es segura para el frontal.
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxx

# Tenant (cliente) cuyo catálogo carga este kiosko
NEXT_PUBLIC_TENANT_SLUG=prosegur
